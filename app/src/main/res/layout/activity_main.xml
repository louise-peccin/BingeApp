<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BingeTrack"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#7B00FF"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Controle de filmes"
        android:textSize="16sp"
        android:textColor="#555555"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnAdicionar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Adicionar filme"
        android:textColor="#FFFFFF"
        android:backgroundTint="#7B00FF"
        android:layout_marginBottom="20dp" />

    <TextView
        android:id="@+id/txtVazio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nenhum filme cadastrado."
        android:textColor="#777777"
        android:textSize="16sp"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginBottom="12dp" />

    <ListView
        android:id="@+id/listViewFilmes"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>